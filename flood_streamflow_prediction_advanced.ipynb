    "\n",
    "# Regime masks\n",
    "low_flow = y_val.values < q25\n",
    "medium_flow = (y_val.values >= q25) & (y_val.values < q75)\n",
    "high_flow = (y_val.values >= q75) & (y_val.values < q95)\n",
    "flood_flow = y_val.values >= q95\n",
    "\n",
    "regimes = {\n",
    "    'Low Flow (Baseflow)': low_flow,\n",
    "    'Medium Flow': medium_flow,\n",
    "    'High Flow': high_flow,\n",
    "    'Flood Peak (Top 5%)': flood_flow\n",
    "}\n",
    "\n",
    "regime_results = []\n",
    "\n",
    "for regime_name, mask in regimes.items():\n",
    "    if mask.sum() > 0:\n",

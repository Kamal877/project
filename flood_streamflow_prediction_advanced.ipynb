    "# ============================================================================\n",
    "# SECTION 2: KGE & NSE METRIC IMPLEMENTATIONS\n",
    "# ============================================================================\n",
    "\n",
    "def kge(obs, sim):\n",
    "    \"\"\"\n",
    "    Kling-Gupta Efficiency (KGE)\n",
    "    KGE = 1 - sqrt(r² + (α-1)² + (β-1)²)\n",
    "    where:\n",
    "    - r: Pearson correlation\n",
    "    - α: std_sim / std_obs\n",
    "    - β: mean_sim / mean_obs\n",
    "    \"\"\"\n",
    "    # Pearson correlation\n",
    "    r = np.corrcoef(obs, sim)[0, 1]\n",
    "    \n",
    "    # Variability ratio (alpha)\n",
    "    alpha = np.std(sim) / np.std(obs)\n",
    "    \n",
    "    # Bias ratio (beta)\n",
    "    beta = np.mean(sim) / np.mean(obs)\n",
    "    \n",
    "    # KGE\n",
    "    kge_val = 1 - np.sqrt(r**2 + (alpha - 1)**2 + (beta - 1)**2)\n",
    "    \n",
    "    return kge_val, r, alpha, beta\n",
    "\n",
    "def nse(obs, sim):\n",
    "    \"\"\"\n",
    "    Nash-Sutcliffe Efficiency\n",
    "    NSE = 1 - (SS_res / SS_tot)\n",
    "    \"\"\"\n",
    "    ss_res = np.sum((obs - sim) ** 2)\n",
    "    ss_tot = np.sum((obs - np.mean(obs)) ** 2)\n",
    "    return 1 - (ss_res / ss_tot)\n",
    "\n",
    "# Test metrics\n",
    "obs_test = np.array([100, 200, 150, 180])\n",
    "sim_test = np.array([95, 210, 145, 185])\n",
    "kge_val, r, alpha, beta = kge(obs_test, sim_test)\n",
    "nse_val = nse(obs_test, sim_test)\n",
    "print(f\"Test KGE: {kge_val:.4f} (r={r:.4f}, α={alpha:.4f}, β={beta:.4f})\")\n",
    "print(f\"Test NSE: {nse_val:.4f}\")"
   ]
  },

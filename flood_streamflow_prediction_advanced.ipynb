   "source": [
    "# ============================================================================\n",
    "# SECTION 9: ENSEMBLE WITH OPTIMIZED WEIGHTS\n",
    "# ============================================================================\n",
    "\n",
    "from scipy.optimize import minimize\n",
    "\n",
    "def kge_negative(weights, pred_xgb, pred_lgb, pred_nn, obs):\n",
    "    \"\"\"\n",
    "    Negative KGE for minimization.\n",
    "    Weights are normalized to sum to 1.\n",
    "    \"\"\"\n",
    "    w = np.abs(weights) / np.sum(np.abs(weights))\n",
    "    ensemble_pred = w[0] * pred_xgb + w[1] * pred_lgb + w[2] * pred_nn\n",
    "    kge_val, _, _, _ = kge(obs, ensemble_pred)\n",
    "    return -kge_val  # Negative because we're minimizing\n",
    "\n",
    "# Optimize weights\n",
    "print(\"Optimizing ensemble weights...\")\n",
    "init_weights = np.array([0.33, 0.33, 0.34])\n",
    "result = minimize(\n",
    "    kge_negative,\n",
    "    init_weights,\n",
    "    args=(y_val_pred_xgb, y_val_pred_lgb, y_val_pred_nn, y_val.values),\n",
    "    method='Nelder-Mead'\n",
    ")\n",
    "\n",
    "optimal_weights = np.abs(result.x) / np.sum(np.abs(result.x))\n",
    "print(f\"Optimal weights: XGBoost={optimal_weights[0]:.4f}, LightGBM={optimal_weights[1]:.4f}, NN={optimal_weights[2]:.4f}\")\n",
    "\n",
    "# Ensemble prediction on validation\n",
    "y_val_pred_ensemble = (optimal_weights[0] * y_val_pred_xgb + \n",
    "                        optimal_weights[1] * y_val_pred_lgb + \n",
    "                        optimal_weights[2] * y_val_pred_nn)\n",
    "\n",
    "kge_ens, r_ens, alpha_ens, beta_ens = kge(y_val.values, y_val_pred_ensemble)\n",
    "nse_ens = nse(y_val.values, y_val_pred_ensemble)\n",
    "\n",
    "print(f\"\\n{'='*60}\")\n",
    "print(f\"ENSEMBLE VALIDATION RESULTS\")\n",
    "print(f\"{'='*60}\")\n",
    "print(f\"  KGE: {kge_ens:.6f} (r={r_ens:.4f}, α={alpha_ens:.4f}, β={beta_ens:.4f})\")\n",
    "print(f\"  NSE: {nse_ens:.6f}\")\n",
    "print(f\"{'='*60}\")\n",
    "\n",
    "# Compare with individual models\n",
    "results_df = pd.DataFrame({\n",
    "    'Model': ['XGBoost', 'LightGBM', 'Neural Network', 'Ensemble'],\n",
    "    'KGE': [kge_xgb, kge_lgb, kge_nn, kge_ens],\n",
    "    'NSE': [nse_xgb, nse_lgb, nse_nn, nse_ens],\n",
    "    'r': [r_xgb, r_lgb, r_nn, r_ens],\n",
    "    'α': [alpha_xgb, alpha_lgb, alpha_nn, alpha_ens],\n",
    "    'β': [beta_xgb, beta_lgb, beta_nn, beta_ens]\n",
    "})\n",
    "\n",
    "print(\"\\nDetailed Results:\")\n",
    "print(results_df.to_string(index=False))"
   ]

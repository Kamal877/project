    "\n",
    "print(f\"\\nNeural Network Validation Results:\")\n",
    "print(f\"  KGE: {kge_nn:.6f} (r={r_nn:.4f}, α={alpha_nn:.4f}, β={beta_nn:.4f})\")\n",
    "print(f\"  NSE: {nse_nn:.6f}\")"
   ]

    "    epochs=200,\n",
    "    batch_size=256,\n",
    "    callbacks=[early_stop, reduce_lr],\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "# Predictions\n",
    "y_val_pred_nn_scaled = nn_model.predict([X_val_scaled, X_val_scaled], verbose=0).ravel()\n",
    "y_val_pred_nn = scaler_y.inverse_transform(y_val_pred_nn_scaled.reshape(-1, 1)).ravel()\n",
    "\n",

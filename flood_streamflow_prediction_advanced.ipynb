    "# ============================================================================\n",
    "# SECTION 3: ADVANCED FEATURE ENGINEERING\n",
    "# ============================================================================\n",
    "\n",
    "def engineer_features(df, target_col='streamflow_tomorrow_cumecs'):\n",
    "    \"\"\"\n",
    "    Advanced feature engineering for hydrological prediction.\n",
    "    \"\"\"\n",
    "    df_feat = df.copy()\n",
    "    \n",
    "    # Separate target if present\n",
    "    has_target = target_col in df_feat.columns\n",
    "    if has_target:\n",
    "        target = df_feat[target_col]\n",
    "        df_feat = df_feat.drop(columns=[target_col])\n",
    "    \n",
    "    # ========== Identify feature groups ==========\n",
    "    rainfall_cols = [col for col in df_feat.columns if 'rainfall' in col.lower() or 'precip' in col.lower()]\n",
    "    flow_cols = [col for col in df_feat.columns if 'flow' in col.lower() or 'cumec' in col.lower()]\n",
    "    saturation_cols = [col for col in df_feat.columns if 'satur' in col.lower() or 'moisture' in col.lower()]\n",
    "    temp_cols = [col for col in df_feat.columns if 'temp' in col.lower()]\n",
    "    \n",
    "    print(f\"Rainfall features: {rainfall_cols}\")\n",
    "    print(f\"Flow features: {flow_cols}\")\n",
    "    print(f\"Saturation features: {saturation_cols}\")\n",
    "    print(f\"Temperature features: {temp_cols}\")\n",
    "    \n",
    "    # ========== Fill missing values ==========\n",
    "    df_feat = df_feat.fillna(method='ffill').fillna(method='bfill').fillna(0)\n",
    "    \n",
    "    # ========== RAINFALL INTERACTION FEATURES ==========\n",
    "    if rainfall_cols and flow_cols:\n",
    "        for rain_col in rainfall_cols:\n",
    "            for flow_col in flow_cols:\n",
    "                df_feat[f'{rain_col}_x_{flow_col}'] = df_feat[rain_col] * df_feat[flow_col]\n",
    "                df_feat[f'{rain_col}_div_{flow_col}'] = df_feat[rain_col] / (df_feat[flow_col] + 1)  # Avoid div by 0\n",
    "    \n",
    "    # ========== FLOW RATE OF CHANGE ==========\n",
    "    if flow_cols:\n",
    "        for flow_col in flow_cols:\n",
    "            df_feat[f'{flow_col}_rate_change'] = df_feat[flow_col].diff().fillna(0)\n",
    "            df_feat[f'{flow_col}_pct_change'] = df_feat[flow_col].pct_change().fillna(0)\n",
    "            df_feat[f'{flow_col}_rolling_3d_mean'] = df_feat[flow_col].rolling(window=3, min_periods=1).mean()\n",
    "            df_feat[f'{flow_col}_rolling_7d_mean'] = df_feat[flow_col].rolling(window=7, min_periods=1).mean()\n",
    "            df_feat[f'{flow_col}_rolling_3d_std'] = df_feat[flow_col].rolling(window=3, min_periods=1).std().fillna(0)\n",
    "    \n",
    "    # ========== RAINFALL ACCUMULATION ==========\n",
    "    if rainfall_cols:\n",
    "        for rain_col in rainfall_cols:\n",
    "            for window in [3, 7, 15, 30]:\n",
    "                df_feat[f'{rain_col}_cum_{window}d'] = df_feat[rain_col].rolling(window=window, min_periods=1).sum()\n",
    "    \n",
    "    # ========== ANTECEDENT PRECIPITATION INDEX (API) ==========\n",
    "    if rainfall_cols:\n",
    "        for rain_col in rainfall_cols:\n",
    "            # Exponential weighted API: recent rainfall weighted more\n",
    "            api = pd.Series(0, index=df_feat.index)\n",
    "            for i in range(1, len(df_feat)):\n",
    "                api.iloc[i] = 0.8 * api.iloc[i-1] + df_feat[rain_col].iloc[i]\n",
    "            df_feat[f'{rain_col}_api'] = api\n",
    "    \n",
    "    # ========== TEMPORAL FEATURES ==========\n",
    "    if 'date' in df_feat.columns or 'datetime' in df_feat.columns:\n",
    "        date_col = 'date' if 'date' in df_feat.columns else 'datetime'\n",
    "        df_feat[date_col] = pd.to_datetime(df_feat[date_col])\n",
    "        df_feat['day_of_year'] = df_feat[date_col].dt.dayofyear\n",
    "        df_feat['month'] = df_feat[date_col].dt.month\n",
    "        df_feat['quarter'] = df_feat[date_col].dt.quarter\n",
    "        df_feat['is_monsoon'] = df_feat['month'].isin([6, 7, 8, 9]).astype(int)  # Jun-Sep\n",
    "        \n",
    "        # Cyclical encoding for day_of_year\n",
    "        df_feat['day_sin'] = np.sin(2 * np.pi * df_feat['day_of_year'] / 365)\n",
    "        df_feat['day_cos'] = np.cos(2 * np.pi * df_feat['day_of_year'] / 365)\n",
    "    \n",
    "    # ========== ANOMALY FEATURES (Z-SCORES) ==========\n",
    "    if rainfall_cols:\n",
    "        for rain_col in rainfall_cols:\n",
    "            mean = df_feat[rain_col].mean()\n",
    "            std = df_feat[rain_col].std()\n",
    "            df_feat[f'{rain_col}_zscore'] = (df_feat[rain_col] - mean) / (std + 1e-5)\n",
    "    \n",
    "    if flow_cols:\n",
    "        for flow_col in flow_cols:\n",
    "            mean = df_feat[flow_col].mean()\n",
    "            std = df_feat[flow_col].std()\n",
    "            df_feat[f'{flow_col}_zscore'] = (df_feat[flow_col] - mean) / (std + 1e-5)\n",
    "    \n",
    "    # ========== SATURATION × RAINFALL INTERACTION ==========\n",
    "    if saturation_cols and rainfall_cols:\n",
    "        for sat_col in saturation_cols:\n",
    "            for rain_col in rainfall_cols:\n",
    "                df_feat[f'{sat_col}_x_{rain_col}'] = df_feat[sat_col] * df_feat[rain_col]\n",
    "    \n",
    "    # Drop date column if it exists (not useful for ML)\n",
    "    if 'date' in df_feat.columns:\n",
    "        df_feat = df_feat.drop(columns=['date'])\n",
    "    if 'datetime' in df_feat.columns:\n",
    "        df_feat = df_feat.drop(columns=['datetime'])\n",
    "    \n",
    "    # Handle inf values\n",
    "    df_feat = df_feat.replace([np.inf, -np.inf], 0)\n",
    "    \n",
    "    print(f\"\\nOriginal features: {len(df.columns)}\")\n",
    "    print(f\"Engineered features: {len(df_feat.columns)}\")\n",
    "    print(f\"New features added: {len(df_feat.columns) - len(df.columns) + (1 if has_target else 0)}\")\n",
    "    \n",
    "    if has_target:\n",
    "        df_feat[target_col] = target\n",
    "    \n",
    "    return df_feat\n",
    "\n",
    "print(\"Feature engineering function defined.\")"
   ]
  },

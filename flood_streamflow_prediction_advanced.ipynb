    "            'KGE': kge_regime,\n",
    "            'NSE': nse_regime,\n",
    "            'r': r_regime,\n",
    "            'MAE': mae_regime,\n",
    "            'RMSE': rmse_regime\n",
    "        })\n",
    "\n",
    "regime_df = pd.DataFrame(regime_results)\n",
    "print(\"\\n\" + regime_df.to_string(index=False))\n",
